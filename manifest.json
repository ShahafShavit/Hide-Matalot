{
  "manifest_version": 3,
  "name": "מנהל תצוגת קורסים במודל",
  "version": "1.3",
  "description": "מנהל תצוגת הגשות למטלות בעמוד הראשי במודל, עבור הגשות בזוגות וקבוצות.",
  "icons": {
    "48": "hide48.png",
    "128": "hide128.png"
  },
  "permissions": ["notifications", "alarms", "storage", "tabs"],
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
    {
      "matches": [
        "*://moodle.ruppin.ac.il/my*"
      ],
      "js": [
        "shared/messageContract.js",
        "content.js"
      ]
    }
  ]
}