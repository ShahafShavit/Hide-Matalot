{
  "manifest_version": 3,
  "name": "מנהל מטלות למודל",
  "version": "1.3.3",
  "description": "מנהל מטלות למודל - הסתרת מטלות, התראות וסנכרון ליומן",
  "icons": {
    "48": "hide48.png",
    "128": "hide128.png"
  },
  "permissions": ["notifications", "alarms", "storage", "tabs"],
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
    {
      "matches": [
      "*://*.ac.il/my/*"
      ],
      "css": [
        "content/ui/hide-matalot.css"
      ],
      "js": [
        "shared/messageContract.js",
        "shared/reminderTime.js",
        "content/debug.js",
        "content/storage/indexedDbState.js",
        "content/messaging/runtimeClient.js",
        "content/domain/assignmentsParser.js",
        "content/ui/notificationSettingsModal.js",
        "content/ui/managementDialog.js",
        "content/orchestration/initController.js",
        "content.js"
      ]
    }
  ]
}